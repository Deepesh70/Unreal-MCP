# Copy this to .env and fill in your API keys
# Only the keys for the provider you want to use are needed.

# ── Groq Cloud ────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Google Gemini ─────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ── Ollama (local) ────────────────────────────────────────────────────
# No API key needed — just make sure Ollama is running on your machine.
# OLLAMA_BASE_URL defaults to http://localhost:11434 if not set.
# OLLAMA_BASE_URL=http://localhost:11434

# ── Builder Token Optimization ────────────────────────────────────────
# Modes: low | balanced | high
# low: fewer tokens (review off, tighter context limits)
# balanced: default behavior
# high: best quality, uses more tokens
# BUILD_TOKEN_MODE=balanced

# Optional overrides:
# BUILD_ENABLE_PLAN_REVIEW=true
# BUILD_ENABLE_JSON_REPAIR=true
# BUILD_MAX_SCENE_CONTEXT_CHARS=2500
# BUILD_MAX_BLUEPRINT_CONTEXT_CHARS=2200
