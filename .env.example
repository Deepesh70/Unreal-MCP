# Copy this to .env and fill in your API keys
# Only the keys for the provider you want to use are needed.

# ── Groq Cloud ────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Google Gemini ─────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ── Ollama (local) ────────────────────────────────────────────────────
# No API key needed — just make sure Ollama is running on your machine.
# OLLAMA_BASE_URL defaults to http://localhost:11434 if not set.
# OLLAMA_BASE_URL=http://localhost:11434

# ── WebSocket Connection ─────────────────────────────────────────────
# Default: ws://127.0.0.1:30020 (Unreal on the same machine).
# For cloud/remote mode, set this to your public tunnel address:
#   UE_WS_URL=ws://your-ngrok-url:30020
# UE_WS_URL=ws://127.0.0.1:30020

# ── Builder Mode (C++ Procedural Architect) ──────────────────────────
# Directory where generated .h/.cpp files are written.
# CPP_OUTPUT_DIR=./generated

# Your Unreal project's API export macro (e.g., MYPROJECT_API).
# Find this in your project's Build.cs or *_API.h file.
# PROJECT_API=YOURPROJECT_API

# Your Unreal project module name (optional, for advanced class paths).
# UE_PROJECT_MODULE=MyProject
